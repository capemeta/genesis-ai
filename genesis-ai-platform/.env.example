# ==================== 应用配置 ====================
APP_NAME=Genesis AI Platform
APP_VERSION=0.1.0
DEBUG=False
# 上下文路径（如果部署在子路径下，如 /genesis-ai）
ROOT_PATH=/
# 公开资源（如 markdown 图片）生成的绝对访问前缀
# 示例: http://localhost:8200 或 http://localhost:8200/genesis-ai
PUBLIC_API_BASE_URL=http://localhost:8200

# ==================== 数据库配置 ====================
# 方式1：直接使用完整的 DATABASE_URL（优先级最高，如果设置了则忽略下面的拆分配置）
# DATABASE_URL=postgresql+asyncpg://username:password@host:5432/database

# 方式2：使用拆分的配置项（推荐，支持密码中的特殊字符）
DB_HOST=localhost
DB_PORT=5432
DB_USER=genesis_app
DB_PASSWORD=genesis_dev_password
DB_NAME=genesis_ai
DB_DRIVER=postgresql+asyncpg

# 数据库连接池配置
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ==================== WebSync 版本清理任务配置 ====================
# 是否启用网页历史版本清理任务
WEB_SYNC_CLEANUP_ENABLED=true
# 清理任务执行时间（每天，24小时制）
WEB_SYNC_CLEANUP_CRON_HOUR=5
WEB_SYNC_CLEANUP_CRON_MINUTE=30
# 每个网页最多保留版本数（始终保留 current）
WEB_SYNC_CLEANUP_MAX_VERSIONS_PER_PAGE=20
# 版本保留天数
WEB_SYNC_CLEANUP_RETENTION_DAYS=180
# 单次清理扫描的页面批量上限
WEB_SYNC_CLEANUP_PAGE_BATCH_SIZE=1000

# ==================== 安全配置 ====================
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256

# Token 过期时间配置（不记住我）
ACCESS_TOKEN_EXPIRE_MINUTES=30  # 30分钟
REFRESH_TOKEN_EXPIRE_DAYS=3     # 3天

# Token 过期时间配置（记住我）
ACCESS_TOKEN_EXPIRE_MINUTES_REMEMBER=120  # 2小时
REFRESH_TOKEN_EXPIRE_DAYS_REMEMBER=30     # 30天

# Token 存储策略
TOKEN_STORAGE=redis  # redis 或 jwt（无状态）
ENABLE_SINGLE_DEVICE_LOGIN=false  # 是否启用单设备登录

# ==================== CORS 配置 ====================
# 允许的前端域名（JSON 数组格式或逗号分隔）
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]

# ==================== 服务端口配置 ====================
PORT=8200

# ==================== 存储配置 ====================
STORAGE_DRIVER=local  # local, s3, seaweedfs

# 本地存储配置（STORAGE_DRIVER=local 时使用）
# 支持相对路径和绝对路径：
# - 相对路径：相对于项目根目录（main.py 所在目录）
#   示例：./storage-data, storage-data, ./data/files
# - 绝对路径：直接使用指定的路径
#   示例：/var/lib/genesis-ai/storage (Linux)
#         C:/data/genesis-ai/storage (Windows)
# 最佳实践：
# - 开发环境：使用相对路径（如 ./storage）
# - 生产环境：使用绝对路径（如 /var/lib/genesis-ai/storage）
LOCAL_STORAGE_PATH=./storage-data

# SeaweedFS/S3 配置（可选）
# SEAWEEDFS_ENDPOINT=http://localhost:8304
# SEAWEEDFS_ACCESS_KEY=GAI_AK_G6PMXBGGLZ6M
# SEAWEEDFS_SECRET_KEY=be5pC1LI5cohK26PMvmNzcBxTBaf85iMN4sdXABS
# SEAWEEDFS_BUCKET=genesis-ai-files
# SEAWEEDFS_REGION=us-east-1

# SeaweedFS/S3 管理员凭证（可选，用于自动创建 bucket）
# 如果配置了管理员凭证，应用启动时会自动检查并创建 bucket
# SEAWEEDFS_ADMIN_ACCESS_KEY=GAI_AK_4VQOIH5HJZ1U
# SEAWEEDFS_ADMIN_SECRET_KEY=l90dyiB62TaQKH2uT8UIIfMPhtKmuepw1vF3xP5m

# ==================== LLM 配置 ====================
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1

# ==================== 检索后端默认配置 ====================
# 当前默认使用 PostgreSQL 本地实现；
# 如未来切换到外部后端，可修改为 qdrant / elasticsearch / opensearch。
DEFAULT_VECTOR_SEARCH_BACKEND=pg_vector
DEFAULT_LEXICAL_SEARCH_BACKEND=pg_fts

# ==================== 文件上传配置 ====================
MAX_UPLOAD_SIZE=104857600  # 100MB

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR_ROOT=./logs
LOG_FILE_WHEN=midnight
LOG_FILE_INTERVAL=1
LOG_FILE_BACKUP_COUNT=14

# ==================== RAG 分块流程并发控制配置 ====================
# 解析任务并发限制（CPU 密集，建议值：CPU 核心数）
RAG_PARSE_CONCURRENCY=4
RAG_PARSE_TASK_SOFT_TIME_LIMIT=3600
RAG_PARSE_TASK_TIME_LIMIT=3660

# 分块任务并发限制（CPU 轻量，建议值：2-4）
RAG_CHUNK_CONCURRENCY=2

# 向量化任务并发限制（I/O 密集，调用 Embedding API，建议值：50-100）
RAG_EMBED_CONCURRENCY=50
# Embedding 热缓存开关（仅做短期热点复用，不替代持久向量索引）
RAG_EMBED_CACHE_ENABLED=true
# Embedding 热缓存 TTL（秒），默认 6 小时
RAG_EMBED_CACHE_TTL_SECONDS=21600
# Embedding 热缓存全局最大条数，超过后裁剪最老条目
RAG_EMBED_CACHE_MAX_ITEMS=2000
# 仅缓存较短文本，避免 Redis 被超长文本 embedding 挤爆
RAG_EMBED_CACHE_MAX_TEXT_LENGTH=4000

# LLM 调用任务并发限制（I/O 密集 + API 限流，建议值：10-20）
RAG_LLM_CONCURRENCY=10
# LLM 并发占满后的处理模式：
# - fail_fast: 立即失败
# - wait: 一直等待
# - wait_timeout: 等待指定秒数后失败
RAG_LLM_CONCURRENCY_MODE=wait
# 当模式为 wait_timeout 时生效
RAG_LLM_CONCURRENCY_WAIT_TIMEOUT_SECONDS=300

# 知识图谱任务并发限制（I/O 密集，建议值：2-5）
RAG_KG_CONCURRENCY=2

# MinIO 上传任务并发限制（I/O 密集，建议值：20-50）
RAG_MINIO_CONCURRENCY=20
# 并发租约 TTL（秒），Worker 异常退出后可自动回收
RAG_CONCURRENCY_LEASE_TTL_SECONDS=600
# 等待模式下的轮询间隔（毫秒）
RAG_CONCURRENCY_POLL_INTERVAL_MS=200

# ==================== MinerU 配置 ====================
MINERU_BASE_URL=http://127.0.0.1:8000
MINERU_CONNECT_TIMEOUT=30
MINERU_READ_TIMEOUT=3600
MINERU_TIMEOUT=3600
# 预览 Markdown 来源策略：
# - auto:        优先使用 MinerU 返回的 md_content，缺失时回退 content_list 转换
# - api_md:      尽量使用 md_content（为空时仍回退）
# - content_list:始终由 content_list/elements 生成，和入库分块更一致
MINERU_PREVIEW_MD_SOURCE=auto
