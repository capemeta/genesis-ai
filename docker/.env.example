# ==================== Docker / Compose 基础配置 ====================
# 原始镜像：
# POSTGRES_IMAGE=pgvector/pgvector:pg18-trixie
# REDIS_IMAGE=redis:7-alpine
# SEAWEEDFS_IMAGE=chrislusf/seaweedfs:latest
# PYTHON_BASE_IMAGE=python:3.12-slim
# NODE_BASE_IMAGE=node:20-bookworm
# NGINX_BASE_IMAGE=nginx:1.27-alpine
#
# 网络受限时默认使用国内镜像代理。
POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg18-trixie
REDIS_IMAGE=docker.m.daocloud.io/redis:7-alpine
SEAWEEDFS_IMAGE=docker.m.daocloud.io/chrislusf/seaweedfs:latest
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:20-bookworm
NGINX_BASE_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
# `docker-compose.full.yml` 生产建议不把 PostgreSQL / Redis / Backend 暴露到宿主机。
# 这里保留端口变量，主要用于容器内约定与必要时的临时排障。
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8200
# 仅内层入口 Nginx 绑定到宿主机回环地址，供外层统一入口 Nginx 反代。
FRONTEND_PORT=5173
# Docker 全量部署会默认使用 ROOT_PATH 作为前端 API 前缀。
# 这里保留 VITE_API_URL，主要用于宿主机本地单独构建前端时覆盖调试。
VITE_API_URL=/
VITE_CLERK_PUBLISHABLE_KEY=

# ==================== 应用配置 ====================
APP_NAME=Genesis AI Platform
APP_VERSION=0.1.0
DEBUG=False
# 上下文路径（如果部署在子路径下，如 /genesis-ai）
# 需要与外层 Nginx 转发前缀保持一致。
ROOT_PATH=/genesis-ai
# 公开资源（如 markdown 图片）生成的绝对访问前缀
# 本地调试可留空，后端会自动回退到 http://localhost:{PORT}{ROOT_PATH}。
# 生产环境如需生成可被外部访问的绝对链接，请显式填写真实域名。
# 示例: https://your-domain.com/genesis-ai
PUBLIC_API_BASE_URL=
# ==================== CORS 配置 ====================
# 默认值偏向本地开发，便于直接启动前后端分离环境。
# 如果正式部署在真实域名下，请务必改成你的线上 origin，例如 ["https://your-domain.com"]。
# 注意：这里只写 origin，不带路径，不能写成 https://your-domain.com/genesis-ai
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# ==================== 数据库配置 ====================
# 使用拆分的配置项（Docker 全量部署默认走服务名）
DB_HOST=postgres
DB_PORT=5432
DB_USER=genesis_app
DB_PASSWORD=genesis_dev_password
DB_NAME=genesis_ai
DB_DRIVER=postgresql+asyncpg

# 数据库连接池配置
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== Redis 配置 ====================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# ==================== WebSync 版本清理任务配置 ====================
WEB_SYNC_CLEANUP_ENABLED=true
WEB_SYNC_CLEANUP_CRON_HOUR=5
WEB_SYNC_CLEANUP_CRON_MINUTE=30
WEB_SYNC_CLEANUP_MAX_VERSIONS_PER_PAGE=20
WEB_SYNC_CLEANUP_RETENTION_DAYS=180
WEB_SYNC_CLEANUP_PAGE_BATCH_SIZE=1000

# ==================== 安全配置 ====================
SECRET_KEY=replace-with-a-strong-secret-key-at-least-32-chars
ALGORITHM=HS256

# Token 过期时间配置（不记住我）
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=3

# Token 过期时间配置（记住我）
ACCESS_TOKEN_EXPIRE_MINUTES_REMEMBER=120
REFRESH_TOKEN_EXPIRE_DAYS_REMEMBER=30

# Token 存储策略
TOKEN_STORAGE=redis
ENABLE_SINGLE_DEVICE_LOGIN=false

# ==================== 服务端口配置 ====================
PORT=8200

# ==================== 存储配置 ====================
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage-data

# SeaweedFS/S3 配置（可选）
SEAWEEDFS_ENDPOINT=http://seaweedfs:8333
SEAWEEDFS_ACCESS_KEY=GAI_AK_G6PMXBGGLZ6M
SEAWEEDFS_SECRET_KEY=be5pC1LI5cohK26PMvmNzcBxTBaf85iMN4sdXABS
SEAWEEDFS_BUCKET=genesis-ai-files
SEAWEEDFS_REGION=us-east-1

# SeaweedFS/S3 管理员凭证（可选，用于自动创建 bucket）
SEAWEEDFS_ADMIN_ACCESS_KEY=GAI_AK_4VQOIH5HJZ1U
SEAWEEDFS_ADMIN_SECRET_KEY=l90dyiB62TaQKH2uT8UIIfMPhtKmuepw1vF3xP5m

# ==================== LLM 配置 ====================
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1

# ==================== 检索后端默认配置 ====================
DEFAULT_VECTOR_SEARCH_BACKEND=pg_vector
DEFAULT_LEXICAL_SEARCH_BACKEND=pg_fts

# ==================== 文件上传配置 ====================
MAX_UPLOAD_SIZE=104857600

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR_ROOT=./logs
LOG_FILE_WHEN=midnight
LOG_FILE_INTERVAL=1
LOG_FILE_BACKUP_COUNT=14

# ==================== RAG 分块流程并发控制配置 ====================
RAG_PARSE_CONCURRENCY=4
RAG_PARSE_TASK_SOFT_TIME_LIMIT=3600
RAG_PARSE_TASK_TIME_LIMIT=3660
RAG_CHUNK_CONCURRENCY=2
RAG_EMBED_CONCURRENCY=50
RAG_EMBED_CACHE_ENABLED=true
RAG_EMBED_CACHE_TTL_SECONDS=21600
RAG_EMBED_CACHE_MAX_ITEMS=2000
RAG_EMBED_CACHE_MAX_TEXT_LENGTH=4000
RAG_LLM_CONCURRENCY=10
RAG_LLM_CONCURRENCY_MODE=wait
RAG_LLM_CONCURRENCY_WAIT_TIMEOUT_SECONDS=300
RAG_KG_CONCURRENCY=2
RAG_MINIO_CONCURRENCY=20
RAG_CONCURRENCY_LEASE_TTL_SECONDS=600
RAG_CONCURRENCY_POLL_INTERVAL_MS=200

# ==================== MinerU 配置 ====================
MINERU_BASE_URL=http://mineru:8000
MINERU_CONNECT_TIMEOUT=30
MINERU_READ_TIMEOUT=3600
MINERU_TIMEOUT=3600
MINERU_PREVIEW_MD_SOURCE=auto

# ==================== Docker 容器内附加配置 ====================
TESSERACT_HOME=/usr/bin
